# Database Configuration
# Default: Use the shared dev database (ask team for credentials)
# Only create a local database if the dev database is down or inaccessible
DB_HOST=your_dev_db_host_here
DB_NAME=cattlelog
DB_USER=your_dev_db_user_here
DB_PASSWORD=your_dev_db_password_here

# Alternative for local PostgreSQL setup (if dev database is unavailable):
# DB_HOST=localhost
# DB_NAME=cattlelog
# DB_USER=postgres
# DB_PASSWORD=your_local_password_here

# Or use full DATABASE_URL instead of individual DB variables:
# DATABASE_URL=postgresql://user:password@host:5432/cattlelog

# Redis Configuration
# Set to "false" to disable caching during development
REDIS_CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379

GOOGLE_API_KEY=your_google_api_key_here
POSTHOG_API_KEY=your_posthog_api_key_here

# Git Commit Hash (automatically set by Render during deployment)
# GIT_COMMIT=abc123

# Optional: Debug flags
# CATALOG_DEBUG_VERSIONS=true
