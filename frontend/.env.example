# PostHog Analytics
# Get your key from https://posthog.com
VITE_POSTHOG_KEY=your_posthog_key_here
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Backend API URLs
# For local development, use localhost:8000
# For production, use the deployed backend URL
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_ALL_COURSES_URL=http://127.0.0.1:8000/api/courses

# Stack Auth (optional - for authentication features)
# Get your keys from https://stack-auth.com
# VITE_STACK_PROJECT_ID=your_project_id_here
# VITE_STACK_PUBLISHABLE_KEY=your_publishable_key_here
